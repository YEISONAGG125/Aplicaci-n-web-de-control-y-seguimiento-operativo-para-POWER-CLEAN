<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>A C SO</title>

<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
}

.top-bar {
    background: #1d2b3a;
    color: white;
    padding: 5px 20px;
    font-size: 14px;
    display: flex;
    justify-content: space-between;
}


.navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 40px;
    background: #f8f8f8;
}

.logo {
    font-size: 28px;
    color: green;
    font-weight: bold;
}

.menu a {
    margin: 0 15px;
    text-decoration: none;
    color: #555;
}

.icons {
    font-size: 18px;
}


.banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 50px;
    background: #eee;
}

.texto {
    max-width: 50%;
}

.texto h1 {
    color: green;
    font-size: 40px;
}

.imagen {
    width: 400px;
    height: 250px;
    border: 2px dashed gray;
    display: flex;
    align-items: center;
    justify-content: center;
    color: gray;
    background: white;
}

.flecha {
    font-size: 30px;
    color: green;
}
</style>
</head>
<body>

<div class="top-bar">
    <div>mail@domain.com | 010-020-0340</div>
    <div>🌐</div>
</div>

<div class="navbar">
    <div class="logo">A C SO</div>

    <div class="menu">
        <a href="#">Home</a>
        <a href="#">About</a>
        <a href="#">Shop</a>
        <a href="#">Contact</a>
    </div>

    <div class="icons">
        🔍 🛒 👤
    </div>
</div>

<div class="banner">
    <div class="flecha">❮</div>

    <div class="texto">
        <h1>Zay eCommerce</h1>
        <p><strong>Tiny and Perfect eCommerce Template</strong></p>
        <p>Aquí puedes poner la descripción de tu tienda.</p>
    </div>

    <div class="imagen">
        Tu imagen aquí
    </div>

    <div class="flecha">❯</div>
</div>

